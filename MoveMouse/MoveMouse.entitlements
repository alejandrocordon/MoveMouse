<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandbox disabled on purpose: posting synthetic mouse events with
         CGEvent (cghidEventTap) requires Accessibility control, which the
         App Sandbox forbids. This is a local automation utility, not a
         Mac App Store app, so the sandbox is not needed. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
